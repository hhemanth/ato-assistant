# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Set to your Vercel deployment URL in Railway, or leave as * for local dev
ALLOWED_ORIGINS=*

# Frontend — set to your Railway URL in Vercel env vars
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase — create project at supabase.com, enable pgvector extension, run schema.sql
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# Voyage AI — get key at voyageai.com (voyage-3-large model)
VOYAGE_API_KEY=pa-...

# LangSmith — get key at smith.langchain.com (free tier works)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=ato-assistant
